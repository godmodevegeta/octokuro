# Ready-to-use API mode: copy this file to .env and replace the three OPENAI values.
# Both http://localhost:3888 and http://<LAN-IP>:3888 work by default.
AI_PROVIDER=api
HOST=0.0.0.0
PORT=3888
OPENAI_API_KEY=your_provider_api_key_here
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6-sol
# Image format sent to the API: webp (default), png, jpeg, or jpg (an alias for jpeg).
# Leave this commented out to use webp.
# SOCRATES_AI_IMAGE_FORMAT=webp
