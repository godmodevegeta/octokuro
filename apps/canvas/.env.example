# Two minimal configurations are provided below.
# Fastest setup:
#   API:   copy env.api.example .env
#   Codex: copy env.codex.example .env
# Both modes allow direct access from localhost and the LAN when HOST=0.0.0.0.

# --- Minimal API configuration (default) ---
AI_PROVIDER=api
HOST=0.0.0.0
PORT=3888
OPENAI_API_KEY=your_provider_api_key_here
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Minimal Codex CLI configuration ---
# Use this block instead of the API block after running `codex login`.
# AI_PROVIDER=codex-cli
# HOST=0.0.0.0
# PORT=3888
# CODEX_CLI_PATH=codex

# Optional settings shared by both modes.
# AUTO_AI_DELAY_SECONDS=1.2
# SOCRATES_DEBUG_ARTIFACTS=false
# SOCRATES_REQUEST_TRACE=false
# SOCRATES_REQUEST_TRACE_LIMIT=100

# Optional API settings.
# OPENAI_API_FORMAT=openai
# Image format sent to the API: webp (default), png, jpeg, or jpg (an alias for jpeg).
# Leave this commented out to use webp.
# SOCRATES_AI_IMAGE_FORMAT=webp

# Optional Codex CLI settings.
# CODEX_CLI_MODEL=
# CODEX_CLI_TIMEOUT_SECONDS=90
# CODEX_CLI_MAX_CONCURRENCY=1
